{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "http://localhost:8008/api/$1"
    },
    {
      "source": "/ws/(.*)",
      "destination": "ws://localhost:8008/ws/$1"
    }
  ]
}
